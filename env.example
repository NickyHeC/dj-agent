# Spotify app credentials (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Dedalus API Key — enables natural language commands (optional)
# Get one at https://dedalus.dev/dashboard/api-keys
DEDALUS_API_KEY=

# LLM model for natural language parsing (default: claude-sonnet)
MODEL=anthropic/claude-sonnet-4-20250514
